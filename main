# ── Helpers ───────────────────────────────────────────────────────────────────
def random_location():
    if random.random() < 0.65:
        p = random.choice(FAMOUS_PLACES)
        name, lat, lng, heading, pitch, region = p
        return {
            "lat":     round(lat + random.uniform(-0.0003, 0.0003), 6),
            "lng":     round(lng + random.uniform(-0.0003, 0.0003), 6),
            "region":  region,
            "heading": (heading + random.randint(-15, 15)) % 360,
            "pitch":   pitch, "place": name, "famous": True,
        }
    weights = [r[5] for r in REGIONS]
    reg = random.choices(REGIONS, weights=weights, k=1)[0]
    rname, lat_min, lat_max, lng_min, lng_max, _ = reg
    return {
        "lat":     round(random.uniform(lat_min, lat_max), 6),
        "lng":     round(random.uniform(lng_min, lng_max), 6),
        "region":  rname, "heading": random.randint(0, 359),
        "pitch":   random.randint(-10, 10), "place": None, "famous": False,
    }

def haversine(lat1, lng1, lat2, lng2):
    R = 6371
    dLat = math.radians(lat2 - lat1); dLng = math.radians(lng2 - lng1)
    a = math.sin(dLat/2)**2 + math.cos(math.radians(lat1))*math.cos(math.radians(lat2))*math.sin(dLng/2)**2
    return R * 2 * math.asin(math.sqrt(a))

def score_from_km(km):
    if km < 0.05: return 5000
    return max(0, round(5000 * math.exp(-km / 2000)))


# ── Persistent headless Selenium driver ───────────────────────────────────────
# One driver instance, reused across all rounds.
# ~3x faster than creating a new browser per screenshot.

_driver = None
_driver_lock = threading.Lock()

def _make_headless_driver():
    opts = Options()
    opts.add_argument("--headless=new")
    opts.add_argument("--no-sandbox")
    opts.add_argument("--disable-dev-shm-usage")
    opts.add_argument("--window-size=1280,720")
    opts.add_argument("--disable-blink-features=AutomationControlled")
    opts.add_argument("--disable-infobars")
    opts.add_argument("--lang=en-US,en;q=0.9")
    opts.add_argument("--disable-extensions")
    opts.add_argument("--disable-gpu")
    opts.add_experimental_option("excludeSwitches", ["enable-automation"])
    opts.add_experimental_option("useAutomationExtension", False)
    opts.add_argument(
        "user-agent=Mozilla/5.0 (Windows NT 10.0; Win64; x64) "
        "AppleWebKit/537.36 (KHTML, like Gecko) Chrome/124.0.0.0 Safari/537.36"
    )
    try:
        svc = Service(ChromeDriverManager().install())
    except Exception:
        svc = Service()
    drv = webdriver.Chrome(service=svc, options=opts)
    drv.execute_script("Object.defineProperty(navigator,'webdriver',{get:()=>undefined})")
    drv.set_page_load_timeout(30)
    return drv

def get_driver():
    """Return the persistent headless driver, recreating if dead."""
    global _driver
    with _driver_lock:
        if _driver is not None:
            try:
                _ = _driver.window_handles   # raises if dead
            except Exception:
                try: _driver.quit()
                except: pass
                _driver = None
        if _driver is None:
            _driver = _make_headless_driver()
        return _driver


# ── Street View URL ───────────────────────────────────────────────────────────
def sv_url(lat, lng, heading, pitch):
    tilt = max(10, min(170, 90 - int(pitch)))
    return (
        f"https://www.google.com/maps/@{lat},{lng},3a,90y,"
        f"{int(heading)}h,{tilt}t"
        f"/data=!3m7!1e1!3m5!1s0!2e0!3e11!7i16384!8i8192"
    )


# ── Popup dismissal ───────────────────────────────────────────────────────────
def _dismiss_popups(driver):
    xpaths = [
        "//button[@jsname='tWT92d']",
        "//button[contains(translate(.,'ABCDEFGHIJKLMNOPQRSTUVWXYZ','abcdefghijklmnopqrstuvwxyz'),'accept all')]",
        "//button[contains(translate(.,'ABCDEFGHIJKLMNOPQRSTUVWXYZ','abcdefghijklmnopqrstuvwxyz'),'i agree')]",
        "//button[contains(translate(.,'ABCDEFGHIJKLMNOPQRSTUVWXYZ','abcdefghijklmnopqrstuvwxyz'),'reject all')]",
        "//button[contains(translate(.,'ABCDEFGHIJKLMNOPQRSTUVWXYZ','abcdefghijklmnopqrstuvwxyz'),'accept')]",
    ]
    for _ in range(6):
        clicked = False
        for xp in xpaths:
            try:
                btn = driver.find_element(By.XPATH, xp)
                if btn.is_displayed() and btn.is_enabled():
                    btn.click(); time.sleep(0.4); clicked = True; break
            except Exception:
                pass
        if not clicked: break
        time.sleep(0.3)


# ── Canvas readiness check ────────────────────────────────────────────────────
def _canvas_ready(driver):
    try:
        return driver.execute_script(
            "for(var c of document.querySelectorAll('canvas'))"
            "{if(c.width>300&&c.height>200)return true;}return false;"
        )
    except Exception:
        return False


# ── Inject CSS+JS to hide all location-revealing UI ───────────────────────────
_HIDE_JS = """
(function(){
  var ID='geospy-hide';
  if(document.getElementById(ID))return;
  var s=document.createElement('style');
  s.id=ID;
  s.textContent=`
    #searchboxinput,.tactile-searchbox-input,.searchbox,.omnibox-container,
    div[jsaction*="searchbox"],#omnibox-singlebox,
    div[aria-label*="Search Google Maps"]{display:none!important}
    div[data-panel-id],div[class*="place-card"],div[class*="section-hero"],
    div[jsaction*="placeCard"],div[class*="image-header"],div[class*="widget-pane"],
    div[class*="scene-header"],div[class*="scene-title"],
    div[class*="ol-overlaycontainer"],.section-layout,
    .place-description{display:none!important}
    .widget-minimap,div[class*="minimap"],
    canvas[class*="minimap"]{display:none!important}
    div[class*="street-name"],div[class*="streetname"],
    .scene-footer,.scene-footer-container,
    .scene-footer-root{display:none!important}
    .gm-style-cc,.gmnoprint,a[href*="maps.google"],
    div[class*="imagery-term"],div[class*="image-term"],
    span[class*="copyright"],div[class*="copyright"],
    .watermark,.fineprint{display:none!important}
    .gm-svpc,.gm-bundled-control,div[class*="widget-zoom"],
    button[jsaction*="zoom"],button[jsaction*="compass"],
    div[class*="fullscreen"],div[data-tooltip]{display:none!important}
    .gb_za,.gb_oa,div[class*="gb_"],#gbwa,
    div[aria-label*="Google Account"],
    a[href*="accounts.google"]{display:none!important}
  `;
  document.head.appendChild(s);
  var sel=[
    '#searchboxinput','div[data-panel-id]','div[class*="place-card"]',
    'div[class*="widget-pane"]','div[class*="scene-header"]',
    '.widget-minimap','div[class*="minimap"]',
    'div[class*="street-name"]','div[class*="streetname"]',
    '.scene-footer','.scene-footer-container','.scene-footer-root',
    '.gm-style-cc','.gmnoprint','a[href*="maps.google"]',
    'div[class*="imagery-term"]','span[class*="copyright"]',
    '.gm-svpc','.gm-bundled-control','div[class*="widget-zoom"]',
    '.gb_za','.gb_oa','div[aria-label*="Google Account"]',
    'div[class*="section-hero"]','div[class*="image-header"]'
  ];
  function hideAll(){
    sel.forEach(function(q){
      document.querySelectorAll(q).forEach(function(el){
        el.style.setProperty('display','none','important');
      });
    });
  }
  hideAll();
  if(!window._geospyHide)window._geospyHide=setInterval(hideAll,1200);
})();
"""


# ── Pillow blur zones (9 zones, expressed as fractional coords) ───────────────
# Tuned for 1280x720. Fractions make them resolution-independent.
#   (x1_frac, y1_frac, x2_frac, y2_frac)
_BLUR_ZONES = [
    (0.00, 0.00, 0.38, 0.09),   # Top-left search bar pill
    (0.00, 0.09, 0.34, 1.00),   # Left info/place card column (full height)
    (0.00, 0.94, 1.00, 1.00),   # Bottom attribution strip (full width)
    (0.00, 0.76, 0.19, 0.94),   # Bottom-left minimap thumbnail
    (0.00, 0.66, 0.34, 0.80),   # Bottom street-name chip
    (0.96, 0.00, 1.00, 1.00),   # Right-edge controls (zoom, compass)
    (0.88, 0.00, 1.00, 0.09),   # Top-right Google account avatar
    (0.38, 0.00, 0.62, 0.07),   # Top-centre Google Maps wordmark
    (0.70, 0.90, 1.00, 1.00),   # Bottom-right "Report a problem" link
]

def _apply_blurs(png_bytes):
    """Apply Gaussian blur over all location-revealing regions."""
    if not PIL_OK:
        return png_bytes
    img = Image.open(io.BytesIO(png_bytes)).convert("RGB")
    w, h = img.size
    BLUR = ImageFilter.GaussianBlur(radius=48)
    for (xf1, yf1, xf2, yf2) in _BLUR_ZONES:
        x1, y1 = max(0, int(w * xf1)), max(0, int(h * yf1))
        x2, y2 = min(w, int(w * xf2)), min(h, int(h * yf2))
        if x2 > x1 and y2 > y1:
            region = img.crop((x1, y1, x2, y2))
            img.paste(region.filter(BLUR), (x1, y1))
    buf = io.BytesIO()
    img.save(buf, format="PNG", optimize=True)
    return buf.getvalue()


# ── Core capture (SSE-friendly, uses persistent driver) ───────────────────────
def capture_street_view(lat, lng, heading, pitch, cb):
    """
    Capture and return a blurred Street View screenshot.
    cb(pct, msg) is called at each step to stream progress.
    Returns (success: bool, b64_image_or_error: str)
    """
    if not SELENIUM_OK:
        return False, "selenium not installed — run: pip install selenium webdriver-manager Pillow"

    url = sv_url(lat, lng, heading, pitch)
    driver = get_driver()

    try:
        cb(5,  "Navigating to Street View")
        driver.get(url)

        cb(20, "Dismissing cookie popups")
        time.sleep(2.5)
        _dismiss_popups(driver)

        cb(35, "Waiting for panorama canvas")
        for _ in range(28):
            if _canvas_ready(driver): break
            time.sleep(0.5)

        if not _canvas_ready(driver):
            return False, "Street View canvas did not load — no coverage at this location"

        cb(60, "Hiding location clues")
        driver.execute_script(_HIDE_JS)
        time.sleep(1.8)

        cb(80, "Taking screenshot")
        png = driver.get_screenshot_as_png()

        cb(90, "Blurring remaining UI")
        blurred = _apply_blurs(png)

        cb(100, "Done")
        return True, base64.b64encode(blurred).decode()

    except Exception as e:
        # Mark driver as dead so get_driver() rebuilds it next round
        global _driver
        with _driver_lock:
            if _driver is driver:
                try: _driver.quit()
                except: pass
                _driver = None
        return False, str(e)


# ── Explore: visible browser window with hidden UI ────────────────────────────
_explore_driver = None
_explore_lock   = threading.Lock()

def _make_visible_driver():
    opts = Options()
    opts.add_argument("--no-sandbox")
    opts.add_argument("--disable-dev-shm-usage")
    opts.add_argument("--window-size=1280,900")
    opts.add_argument("--disable-blink-features=AutomationControlled")
    opts.add_argument("--disable-infobars")
    opts.add_argument("--lang=en-US,en;q=0.9")
    opts.add_experimental_option("excludeSwitches", ["enable-automation"])
    opts.add_experimental_option("useAutomationExtension", False)
    opts.add_argument(
        "user-agent=Mozilla/5.0 (Windows NT 10.0; Win64; x64) "
        "AppleWebKit/537.36 (KHTML, like Gecko) Chrome/124.0.0.0 Safari/537.36"
    )
    try:
        svc = Service(ChromeDriverManager().install())
    except Exception:
        svc = Service()
    drv = webdriver.Chrome(service=svc, options=opts)
    drv.execute_script("Object.defineProperty(navigator,'webdriver',{get:()=>undefined})")
    drv.set_page_load_timeout(30)
    return drv

def open_explore_tab(lat, lng, heading, pitch):
    global _explore_driver
    if not SELENIUM_OK:
        import webbrowser
        webbrowser.open(sv_url(lat, lng, heading, pitch))
        return
    url = sv_url(lat, lng, heading, pitch)
    with _explore_lock:
        try:
            if _explore_driver: _ = _explore_driver.window_handles
        except Exception:
            _explore_driver = None
        if _explore_driver is None:
            _explore_driver = _make_visible_driver()
        _explore_driver.execute_script("window.open('');")
        _explore_driver.switch_to.window(_explore_driver.window_handles[-1])
        _explore_driver.get(url)

    def _keep_hiding():
        for _ in range(90):
            time.sleep(1)
            try:
                with _explore_lock:
                    if _explore_driver: _explore_driver.execute_script(_HIDE_JS)
            except Exception:
                break
    threading.Thread(target=_keep_hiding, daemon=True).start()

def close_explore_tab():
    global _explore_driver
    with _explore_lock:
        try:
            if _explore_driver and len(_explore_driver.window_handles) > 1:
                _explore_driver.close()
                _explore_driver.switch_to.window(_explore_driver.window_handles[-1])
        except Exception:
            pass


# ── Flask routes ──────────────────────────────────────────────────────────────

@app.route("/")
def index():
    return render_template_string(GAME_HTML)

@app.route("/api/status")
def api_status():
    return jsonify({"selenium": SELENIUM_OK, "pillow": PIL_OK})

@app.route("/api/round")
def api_round():
    return jsonify(random_location())

@app.route("/api/screenshot/stream")
def api_screenshot_stream():
    """
    SSE endpoint — streams real-time progress while Selenium captures.

    Query params: lat, lng, heading, pitch

    Emits:
      data: {"type":"progress","pct":N,"msg":"..."}
      data: {"type":"done","image":"<base64>"}
      data: {"type":"error","error":"..."}
    """
    lat     = float(request.args.get("lat", 0))
    lng     = float(request.args.get("lng", 0))
    heading = int(request.args.get("heading", 0))
    pitch   = int(request.args.get("pitch", 0))

    q = queue.Queue()

    def cb(pct, msg):
        q.put({"type": "progress", "pct": pct, "msg": msg})

    def worker():
        ok, result = capture_street_view(lat, lng, heading, pitch, cb)
        if ok:
            q.put({"type": "done", "image": result})
        else:
            q.put({"type": "error", "error": result})

    threading.Thread(target=worker, daemon=True).start()

    def generate():
        while True:
            try:
                event = q.get(timeout=65)
            except queue.Empty:
                yield 'data: {"type":"error","error":"timeout"}\n\n'
                return
            yield f"data: {json.dumps(event)}\n\n"
            if event["type"] in ("done", "error"):
                return

    return Response(
        generate(),
        mimetype="text/event-stream",
        headers={"Cache-Control": "no-cache", "X-Accel-Buffering": "no"},
    )

@app.route("/api/explore", methods=["POST"])
def api_explore():
    d = request.get_json()
    threading.Thread(
        target=open_explore_tab,
        args=(d.get("lat"), d.get("lng"), d.get("heading", 0), d.get("pitch", 0)),
        daemon=True,
    ).start()
    return jsonify({"success": True})

@app.route("/api/explore/close", methods=["POST"])
def api_explore_close():
    close_explore_tab()
    return jsonify({"success": True})

@app.route("/api/score", methods=["POST"])
def api_score():
    d = request.get_json()
    km = haversine(d["actual_lat"], d["actual_lng"], d["guess_lat"], d["guess_lng"])
    return jsonify({"km": round(km, 2), "score": score_from_km(km)})


