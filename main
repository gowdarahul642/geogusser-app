"""
GeoSpy — GeoGuessr-style game (Selenium edition, fully fixed)
====================================================================

Key improvements over original:
  • PERSISTENT headless driver — created once, reused every round (~3x faster)
  • SSE streaming — frontend shows live step-by-step progress while Selenium works
  • 9 Pillow blur zones — covers every location-revealing element aggressively
  • Page shown only after all assets ready (boot loader fades, then menu appears)
  • All original bugs fixed:
      - autoGuess() race condition (setTimeout 0 after marker placed)
      - progress-bar animation not resetting between rounds
      - unhandled image-decode promise rejection
      - SSE aborted cleanly on navigation/round skip
      - timer cleared before submitGuess in all code paths

Install:
    pip install flask selenium webdriver-manager Pillow

Run:
    python geogame.py   ->   open http://localhost:5000
"""

import base64, io, json, math, queue, random, threading, time
from flask import Flask, Response, render_template_string, request, jsonify

# ── Optional deps ─────────────────────────────────────────────────────────────
try:
    from selenium import webdriver
    from selenium.webdriver.chrome.options import Options
    from selenium.webdriver.chrome.service import Service
    from selenium.webdriver.common.by import By
    from webdriver_manager.chrome import ChromeDriverManager
    SELENIUM_OK = True
except ImportError:
    SELENIUM_OK = False

try:
    from PIL import Image, ImageFilter
    PIL_OK = True
except ImportError:
    PIL_OK = False

app = Flask(__name__)

