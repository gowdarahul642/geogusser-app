<script>
/* ── State ── */
let totalRounds=5, currentRound=0, totalScore=0;
let roundHistory=[], currentLoc=null;
let guessMarker=null, map=null, resultMap=null;
let timerInterval=null, timeLeft=90;
let curHeading=0, curPitch=0;
let lookLoading=false, exploreOpen=false;
let currentSSE=null;

/* ── Boot sequence ──
   Wait for fonts + server status check before showing menu.
   This ensures the page never appears half-loaded.
── */
(async function boot(){
  setBootMsg('Loading fonts…');
  try{ await document.fonts.ready }catch(_){}

  setBootMsg('Checking server…');
  let status={};
  try{ status=await fetch('/api/status').then(r=>r.json()) }catch(_){}

  if(!status.selenium){
    document.getElementById('sel-warn').style.display='';
  }

  setBootMsg('Ready!');
  await sleep(380);
  document.getElementById('boot').classList.add('gone');
  show('menu');
})();

function setBootMsg(m){ document.getElementById('boot-msg').textContent=m }
function sleep(ms){ return new Promise(r=>setTimeout(r,ms)) }

/* ── Screen system ── */
function show(id){
  document.querySelectorAll('.screen').forEach(s=>s.classList.toggle('hidden',s.id!==id));
}
function goMenu(){ clearTimer(); abortSSE(); closeExplore(); show('menu') }
function goRoundPick(){ show('rounds-pick') }
function selectRounds(n,el){
  totalRounds=n;
  document.querySelectorAll('.ropt').forEach(b=>b.classList.remove('sel'));
  el.classList.add('sel');
}
function showHow(){
  alert(
    "GeoSpy — How to Play\n\n"+
    "1. Selenium captures a real Google Street View screenshot.\n"+
    "   All location-revealing UI (search bar, minimap, labels,\n"+
    "   attribution, controls) is removed via CSS + Pillow blur.\n\n"+
    "2. Watch the live progress steps while Selenium works.\n\n"+
    "3. Use the ▲ ◀ ▶ arrows to look around — re-captures at a new angle.\n\n"+
    "4. Click 'Explore in new tab' to open the same location in a\n"+
    "   visible Selenium window — walk around freely (UI still hidden).\n\n"+
    "5. Click the world map to drop your guess pin, then hit 'Place your guess'.\n"+
    "   Closer = more points. Max 5,000 per round.\n\n"+
    "65% of rounds are famous landmarks. Good luck!"
  );
}

/* ── Game start ── */
function startGame(){
  currentRound=0; totalScore=0; roundHistory=[];
  show('game'); initMap(); buildPips(); loadRound();
}
function buildPips(){
  const c=document.getElementById('pips'); c.innerHTML='';
  for(let i=0;i<totalRounds;i++){
    const d=document.createElement('div');
    d.className='pip'+(i===0?' active':''); d.id='pip-'+i; c.appendChild(d);
  }
}
function updatePips(){
  for(let i=0;i<totalRounds;i++){
    const p=document.getElementById('pip-'+i); if(!p)return;
    p.className=i<currentRound?'pip done':i===currentRound?'pip active':'pip';
  }
}

/* ── Leaflet map ── */
function initMap(){
  if(map){map.remove();map=null}
  setTimeout(()=>{
    map=L.map('map',{zoomControl:true,attributionControl:false}).setView([20,0],2);
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png',{maxZoom:18}).addTo(map);
    map.on('click',onMapClick);
  },120);
}
function onMapClick(e){
  const{lat,lng}=e.latlng;
  if(guessMarker)map.removeLayer(guessMarker);
  guessMarker=L.circleMarker([lat,lng],{radius:10,color:'#efc94c',fillColor:'#efc94c',fillOpacity:.9,weight:2}).addTo(map);
  document.getElementById('guess-btn').disabled=false;
  document.getElementById('map-hint').textContent=`Pinned: ${lat.toFixed(3)}, ${lng.toFixed(3)}`;
}

/* ── SSE loader helpers ── */
const STEP_PCT=[5,20,35,60,80,90];  // which pct activates each step index

function abortSSE(){ if(currentSSE){currentSSE.close();currentSSE=null} }

function resetLoader(){
  for(let i=0;i<6;i++){const e=document.getElementById('step-'+i);if(e)e.className='sv-step'}
  document.getElementById('sl-fill').style.transition='none';
  document.getElementById('sl-fill').style.width='0%';
  // Force reflow so the transition reset takes effect before next frame
  void document.getElementById('sl-fill').offsetWidth;
  document.getElementById('sl-fill').style.transition='width .4s ease';
}
function updateSteps(pct){
  STEP_PCT.forEach((thresh,i)=>{
    const el=document.getElementById('step-'+i); if(!el)return;
    const nextThresh=STEP_PCT[i+1]||101;
    if(pct>=nextThresh)      el.className='sv-step done';
    else if(pct>=thresh)     el.className='sv-step active';
    else                     el.className='sv-step';
  });
}
function setProgress(pct,lbl,sub=''){
  document.getElementById('sl-fill').style.width=pct+'%';
  document.getElementById('sl-lbl').textContent=lbl;
  document.getElementById('sl-sub').textContent=sub;
  updateSteps(pct);
}
function showLoader(){ resetLoader(); document.getElementById('sv-loader').classList.remove('hidden') }
function hideLoader(){ document.getElementById('sv-loader').classList.add('hidden') }

/* ── Load round ── */
async function loadRound(){
  abortSSE(); closeExplore();
  if(map&&guessMarker){map.removeLayer(guessMarker);guessMarker=null}
  document.getElementById('guess-btn').disabled=true;
  document.getElementById('map-hint').textContent='Click on the map to place your guess';
  document.getElementById('hud-round').textContent=`Round ${currentRound+1} / ${totalRounds}`;
  document.getElementById('sv-img').classList.remove('show');
  document.getElementById('sv-nodata').classList.remove('show');
  document.getElementById('explore-btn').className='sv-explore-btn';
  setCtrlsDisabled(true);
  const fb=document.getElementById('famous-badge');
  fb.textContent=''; fb.classList.remove('show');
  updatePips();
  showLoader();
  setProgress(2,'Fetching location…');

  let loc;
  try{
    loc=await fetch('/api/round').then(r=>r.json());
  }catch(e){
    setProgress(0,'Network error','Could not reach server');
    return;
  }
  currentLoc=loc; curHeading=loc.heading; curPitch=loc.pitch||0;
  if(loc.famous){ document.getElementById('famous-badge').textContent='\u2605 Landmark'; document.getElementById('famous-badge').classList.add('show') }

  await streamCapture(loc.lat,loc.lng,curHeading,curPitch,false);
}

/* ── SSE stream capture ── */
// Friendly labels for each progress pct bracket
const PCT_LABELS={
  5:  ['Navigating to Street View…',    'Opening Google Maps in headless Chrome'],
  20: ['Handling cookie popups…',       'Dismissing consent dialogs'],
  35: ['Waiting for panorama canvas…',  'Street View is rendering the 360° scene'],
  60: ['Hiding location clues…',        'Injecting CSS to remove signs & labels'],
  80: ['Taking screenshot…',            'Capturing the full browser viewport'],
  90: ['Blurring remaining UI…',        'Applying Gaussian blur to overlay zones'],
};

function streamCapture(lat,lng,heading,pitch,isLook){
  return new Promise(resolve=>{
    abortSSE();
    const url=`/api/screenshot/stream?lat=${lat}&lng=${lng}&heading=${heading}&pitch=${pitch}`;
    const sse=new EventSource(url);
    currentSSE=sse;

    sse.onmessage=(e)=>{
      let ev; try{ev=JSON.parse(e.data)}catch(_){return}

      if(ev.type==='progress'){
        let lbl=ev.msg, sub='';
        for(const[thresh,[l,s]] of Object.entries(PCT_LABELS)){
          if(ev.pct>=Number(thresh)){lbl=l;sub=s}
        }
        setProgress(ev.pct,lbl,sub);

      }else if(ev.type==='done'){
        sse.close(); currentSSE=null;
        setProgress(100,'Rendering image…','');
        setTimeout(async()=>{
          const img=document.getElementById('sv-img');
          try{
            await new Promise((res,rej)=>{ img.onload=res; img.onerror=rej; img.src='data:image/png;base64,'+ev.image });
            img.classList.add('show');
            hideLoader();
            setCtrlsDisabled(false);
            document.getElementById('explore-btn').className='sv-explore-btn vis';
            if(!isLook) startTimer();
          }catch(_){
            hideLoader();
            document.getElementById('sv-nodata').classList.add('show');
            if(!isLook) setTimeout(loadRound,2500);
            else setCtrlsDisabled(false);
          }
          resolve();
        },280);

      }else if(ev.type==='error'){
        sse.close(); currentSSE=null;
        hideLoader();
        document.getElementById('sv-nodata').classList.add('show');
        if(!isLook) setTimeout(loadRound,2500);
        else setCtrlsDisabled(false);
        resolve();
      }
    };

    sse.onerror=()=>{
      sse.close(); currentSSE=null;
      hideLoader();
      document.getElementById('sv-nodata').classList.add('show');
      if(!isLook) setTimeout(loadRound,2500);
      else setCtrlsDisabled(false);
      resolve();
    };
  });
}

/* ── Look around ── */
function setCtrlsDisabled(dis){
  ['ctrl-up','ctrl-left','ctrl-right'].forEach(id=>{const el=document.getElementById(id);if(el)el.disabled=dis});
}
async function lookAround(dH,dP){
  if(lookLoading||!currentLoc)return;
  lookLoading=true; setCtrlsDisabled(true);
  document.getElementById('explore-btn').className='sv-explore-btn';
  document.getElementById('sv-img').classList.remove('show');
  showLoader(); setProgress(2,'Rotating view…');
  curHeading=((curHeading+dH)%360+360)%360;
  curPitch=Math.max(-60,Math.min(60,curPitch+dP));
  await streamCapture(currentLoc.lat,currentLoc.lng,curHeading,curPitch,true);
  lookLoading=false;
}

/* ── Explore ── */
async function openExplore(){
  if(!currentLoc)return;
  const btn=document.getElementById('explore-btn');
  btn.innerHTML='<span class="eicon">&#8987;</span> Opening…'; btn.disabled=true;
  try{
    await fetch('/api/explore',{method:'POST',headers:{'Content-Type':'application/json'},
      body:JSON.stringify({lat:currentLoc.lat,lng:currentLoc.lng,heading:curHeading,pitch:curPitch})});
    exploreOpen=true;
    document.getElementById('explore-bar').classList.add('show');
    btn.innerHTML='<span class="eicon">&#128065;</span> Tab open';
  }catch(_){
    btn.innerHTML='<span class="eicon">&#10060;</span> Failed';
  }
  btn.disabled=false;
}
async function closeExplore(){
  if(!exploreOpen)return; exploreOpen=false;
  document.getElementById('explore-bar').classList.remove('show');
  try{await fetch('/api/explore/close',{method:'POST'})}catch(_){}
  const btn=document.getElementById('explore-btn');
  if(btn) btn.innerHTML='<span class="eicon">&#127758;</span> Explore in new tab';
}

/* ── Timer ── */
function startTimer(){ clearTimer(); timeLeft=90; updateTimerDisplay(); timerInterval=setInterval(()=>{timeLeft--;updateTimerDisplay();if(timeLeft<=0){clearTimer();autoGuess()}},1000) }
function clearTimer(){ if(timerInterval){clearInterval(timerInterval);timerInterval=null} }
function updateTimerDisplay(){const e=document.getElementById('timer');e.textContent=timeLeft;e.className='hud-timer'+(timeLeft<=15?' low':'')}

/* ── Auto-guess (timer expiry)
   FIX: place marker FIRST, then call submitGuess in a separate task
        so guessMarker is guaranteed non-null when submitGuess reads it.
── */
function autoGuess(){
  if(!guessMarker&&map){
    const lat=(Math.random()*120)-60, lng=(Math.random()*340)-170;
    guessMarker=L.circleMarker([lat,lng],{radius:8,color:'#e8453c',fillColor:'#e8453c',fillOpacity:.7,weight:2}).addTo(map);
    document.getElementById('guess-btn').disabled=false;
  }
  setTimeout(submitGuess,0);
}

/* ── Submit guess ── */
async function submitGuess(){
  clearTimer(); closeExplore();
  if(!guessMarker)return;
  const gLat=guessMarker.getLatLng().lat, gLng=guessMarker.getLatLng().lng;
  const aLat=currentLoc.lat, aLng=currentLoc.lng;
  const res=await fetch('/api/score',{method:'POST',headers:{'Content-Type':'application/json'},
    body:JSON.stringify({guess_lat:gLat,guess_lng:gLng,actual_lat:aLat,actual_lng:aLng})});
  const data=await res.json();
  totalScore+=data.score;
  roundHistory.push({round:currentRound+1,region:currentLoc.region,score:data.score,km:data.km,actual:[aLat,aLng],guess:[gLat,gLng]});
  document.getElementById('hud-score').textContent=totalScore.toLocaleString();
  showResult(data,gLat,gLng,aLat,aLng);
}

/* ── Result screen ── */
function showResult(data,gLat,gLng,aLat,aLng){
  document.getElementById('res-score').textContent=data.score.toLocaleString();
  document.getElementById('res-dist').textContent=data.km<1?Math.round(data.km*1000)+' m':Math.round(data.km).toLocaleString()+' km';
  document.getElementById('res-region').textContent='\uD83D\uDCCD '+currentLoc.region;
  const rp=document.getElementById('reveal-place'),rn=document.getElementById('reveal-name');
  if(currentLoc.famous&&currentLoc.place){rn.textContent=currentLoc.place;rp.classList.add('show')}else rp.classList.remove('show');
  document.getElementById('next-btn').textContent=currentRound===totalRounds-1?'See Final Score \u2192':'Next Round \u2192';
  show('result');
  setTimeout(()=>{
    if(resultMap){resultMap.remove();resultMap=null}
    resultMap=L.map('result-map',{zoomControl:false,attributionControl:false});
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png').addTo(resultMap);
    const aLL=[aLat,aLng],gLL=[gLat,gLng];
    L.circleMarker(aLL,{radius:12,color:'#3dd68c',fillColor:'#3dd68c',fillOpacity:1,weight:3}).addTo(resultMap).bindPopup('\uD83C\uDFAF Actual').openPopup();
    L.circleMarker(gLL,{radius:10,color:'#efc94c',fillColor:'#efc94c',fillOpacity:.9,weight:2}).addTo(resultMap).bindPopup('\uD83D\uDCCD Your guess');
    L.polyline([aLL,gLL],{color:'#e8453c',weight:2,dashArray:'6,4',opacity:.8}).addTo(resultMap);
    resultMap.fitBounds(L.latLngBounds([aLL,gLL]),{padding:[44,44]});
  },200);
}

/* ── Next round / final ── */
function nextRound(){
  currentRound++;
  if(currentRound>=totalRounds){showFinal();return}
  show('game'); loadRound();
}
function showFinal(){
  const max=totalRounds*5000;
  document.getElementById('final-total').innerHTML=totalScore.toLocaleString()+' <span>pts</span>';
  document.getElementById('final-max').textContent='out of '+max.toLocaleString();
  const pct=totalScore/max;
  document.getElementById('final-grade').innerHTML=
    pct>=.95?'\uD83C\uDFC6 <strong>Geographic Genius!</strong>':
    pct>=.80?'\uD83C\uDF0D <strong>World Explorer</strong> \u2014 Impressive!':
    pct>=.60?'\u2708\uFE0F <strong>Seasoned Traveler</strong> \u2014 Solid!':
    pct>=.40?'\uD83D\uDDFA\uFE0F <strong>Getting There</strong> \u2014 Keep exploring!':
    '\uD83C\uDF31 <strong>Beginner</strong> \u2014 The world awaits!';
  document.getElementById('final-breakdown').innerHTML=roundHistory.map(r=>`
    <div class="fb-row">
      <div>
        <div class="fb-round">Round ${r.round}</div>
        <div class="fb-region">${r.region}</div>
        <div class="fb-dist">${r.km<1?Math.round(r.km*1000)+' m':Math.round(r.km).toLocaleString()+' km'} away</div>
      </div>
      <div class="fb-score">${r.score.toLocaleString()}</div>
    </div>`).join('');
  show('final');
}
</script>
</body>
</html>
"""

if __name__ == "__main__":
    print("\n  GeoSpy  |  http://localhost:5000")
    print("  ─────────────────────────────────")
    if not SELENIUM_OK:
        print("  ⚠  MISSING: pip install selenium webdriver-manager Pillow")
    else:
        print(f"  ✓  Selenium OK  |  Pillow: {'OK' if PIL_OK else 'MISSING — pip install Pillow'}")
    print()
    app.run(debug=False, port=5000, threaded=True)
